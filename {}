    if (this.overflowQueue.length === 0) {
      return;
    }

    let retries = 0;
    while (retries < this.MAX_RETRIES && this.overflowQueue.length > 0) {
      try {
        const eventsToPersist = [...this.overflowQueue];
        await this.storage.persist(eventsToPersist);
        this.overflowQueue = [];
        break;
