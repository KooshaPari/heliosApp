        this.metrics.sqliteWriteFailures!++;
        this.metrics.sqliteRetryCount!++;
        retries++;
        if (retries < this.MAX_RETRIES) {
          await new Promise(resolve =>
            setTimeout(resolve, this.RETRY_BACKOFF_MS * Math.pow(2, retries - 1))
          );
        }
      }
    }
