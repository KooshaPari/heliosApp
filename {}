    }

    this.buffer.push(event);

    if (this.buffer.length > this.metrics.bufferHighWaterMark) {
      this.metrics.bufferHighWaterMark = this.buffer.length;
    }

    if (this.buffer.length >= this.MAX_BUFFER_SIZE) {
