{
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "node_modules/**",
    "docs/.vitepress/dist/**",
    "apps/**/dist/**",
    "docs/.generated/**",
    ".worktrees/**",
    "kitty-specs/**",
    "docs/sessions/**",
    "tsconfig*.json"
  ],
  "rules": {
    "no-complexity": {
      "level": "off"
    }
  }
}
