{
  "name": "heliosapp",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.20",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.20"
  },
  "workspaces": [
    "apps/runtime",
    "apps/desktop",
    "apps/colab-renderer",
    "packages/errors",
    "packages/ids",
    "packages/logger",
    "packages/runtime-core",
    "packages/types"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint apps/",
    "format": "biome format --write apps docs/.vitepress playwright.config.ts tsconfig.json package.json",
    "test": "bun test apps/runtime/tests/unit scripts/tests/",
    "test:desktop": "bun test apps/desktop/tests/unit",
    "test:integration": "bun test apps/runtime/tests/integration",
    "test:coverage": "bun test --coverage apps/runtime/tests/unit apps/desktop/tests/unit",
    "test:e2e": "playwright test",
    "gates": "bun scripts/gates.ts",
    "docs:index": "bash docs/scripts/generate-doc-index.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "bun run docs:index && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deps:status": "bun scripts/deps-status.ts",
    "deps:rollback": "bun scripts/deps-rollback.ts",
    "deps:canary": "bun scripts/deps-canary.ts",
    "deps:log": "bun scripts/deps-canary.ts log"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "date-fns": "4.1.0",
    "ky": "1.14.3",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "bun-types": "1.3.11",
    "esbuild": "^0.27.3",
    "esbuild-plugin-solid": "^0.6.0",
    "happy-dom": "20.8.9",
    "oxlint": "latest",
    "typescript": "6.0.2",
    "vitepress": "1.6.4",
    "vitest": "4.1.2"
  }
}