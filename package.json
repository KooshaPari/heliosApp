{
  "name": "heliosapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.20",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c .oxlintrc.json apps docs/.vitepress playwright.config.ts",
    "lint:type-aware": "oxlint -c .oxlintrc.json --type-aware --tsconfig tsconfig.json apps/runtime/src apps/desktop/src",
    "format": "oxfmt --write apps docs/.vitepress playwright.config.ts tsconfig.json package.json",
    "format:check": "oxfmt --check apps docs/.vitepress playwright.config.ts tsconfig.json package.json",
    "test": "bun test apps/runtime apps/desktop/tests/unit",
    "test:coverage": "bun test --coverage apps/runtime apps/desktop/tests/unit",
    "test:e2e": "playwright test",
    "docs:index": "bash docs/scripts/generate-doc-index.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "bun run docs:index && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "governance:query": "tsx scripts/governance-log.ts"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@playwright/test": "1.51.1",
    "@types/node": "22.13.10",
    "bun-types": "1.2.9",
    "esbuild": "^0.27.3",
    "esbuild-plugin-solid": "^0.6.0",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0",
    "typescript": "5.8.2",
    "vitepress": "1.6.3"
  }
}
