{
  "name": "heliosapp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/runtime",
    "apps/desktop"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --config .oxlintrc.json apps docs/.vitepress playwright.config.ts tsconfig.json",
    "format": "oxfmt --config .oxfmtrc.json --write apps docs/.vitepress playwright.config.ts tsconfig.json",
    "test": "bun test apps/runtime/tests/unit scripts/tests/",
    "test:desktop": "bun test apps/desktop/tests/unit",
    "test:integration": "bun test apps/runtime/tests/integration",
    "test:coverage": "bun test --coverage apps/runtime/tests/unit apps/desktop/tests/unit",
    "test:e2e": "playwright test",
    "gates": "bun scripts/gates.ts",
    "docs:index": "bash docs/scripts/generate-doc-index.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "bun run docs:index && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deps:status": "bun scripts/deps-status.ts",
    "deps:rollback": "bun scripts/deps-rollback.ts",
    "deps:canary": "bun scripts/deps-canary.ts",
    "deps:log": "bun scripts/deps-canary.ts log"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "22.13.10",
    "bun-types": "1.3.10",
    "esbuild": "^0.27.3",
    "esbuild-plugin-solid": "^0.6.0",
    "happy-dom": "20.8.7",
    "oxlint": "latest",
    "typescript": "5.8.2",
    "vitepress": "1.6.3"
  },
  "packageManager": "bun@1.2.20"
}
