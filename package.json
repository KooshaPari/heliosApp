{
  "name": "heliosapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint apps docs/.vitepress playwright.config.ts",
    "lint:type-aware": "oxlint --type-aware --tsconfig tsconfig.json apps/runtime/src apps/desktop/src",
    "format": "oxfmt --write apps docs/.vitepress playwright.config.ts tsconfig.json package.json",
    "format:check": "oxfmt --check apps docs/.vitepress playwright.config.ts tsconfig.json package.json",
    "test": "bun test apps/runtime apps/desktop/tests/unit",
    "test:coverage": "bun test --coverage apps/runtime apps/desktop/tests/unit",
    "test:e2e": "playwright test",
    "docs:index": "bash docs/scripts/generate-doc-index.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "bun run docs:index && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@playwright/test": "1.51.1",
    "@types/node": "22.13.10",
    "bun-types": "1.2.9",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0",
    "typescript": "5.8.2",
    "vitepress": "1.6.3"
  },
  "packageManager": "bun@1.2.20"
}
