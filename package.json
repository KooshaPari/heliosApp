{
  "name": "heliosapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.20",
  "workspaces": [
    "apps/runtime",
    "apps/desktop"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check apps docs/.vitepress playwright.config.ts tsconfig.json package.json",
    "format": "biome format --write apps docs/.vitepress playwright.config.ts tsconfig.json package.json",
    "test": "bun test apps/runtime apps/desktop/tests/unit scripts/tests/",
    "test:coverage": "bun test --coverage apps/runtime apps/desktop/tests/unit",
    "test:e2e": "playwright test",
    "gates": "bun scripts/gates.ts",
    "docs:index": "bash docs/scripts/generate-doc-index.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "bun run docs:index && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deps:status": "bun scripts/deps-status.ts",
    "deps:rollback": "bun scripts/deps-rollback.ts",
    "deps:canary": "bun scripts/deps-canary.ts",
    "deps:log": "bun scripts/deps-canary.ts log"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "solid-js": "^1.9.11"
  },
  "dependencies": {
    "solid-js": "^1.9.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "1.51.1",
    "@types/node": "22.13.10",
    "bun-types": "1.2.9",
    "esbuild": "^0.27.3",
    "esbuild-plugin-solid": "^0.6.0",
    "typescript": "5.8.2",
    "vitepress": "1.6.3"
  },
  "dependencies": {
    "solid-js": "^1.9.11"
  }
}
