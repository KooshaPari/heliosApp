{
  "name": "@phenotype/metrics",
  "version": "0.1.0",
  "description": "High-performance metrics collection and aggregation for Phenotype applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ring-buffer": {
      "import": "./dist/ring-buffer.js",
      "types": "./dist/ring-buffer.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["metrics", "observability", "performance", "telemetry", "phenotype"],
  "files": ["dist"],
  "devDependencies": {
    "vitest": "^2.0.0"
  }
}
