{
  "name": "@phenotype/template-hexagonal",
  "version": "0.1.0",
  "description": "Hexagonal architecture template for Phenotype packages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./domain": {
      "import": "./dist/domain/index.js",
      "types": "./dist/domain/index.d.ts"
    },
    "./ports": {
      "import": "./dist/domain/ports/index.js",
      "types": "./dist/domain/ports/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["hexagonal-architecture", "ports-and-adapters", "template", "phenotype"],
  "files": ["dist"]
}
