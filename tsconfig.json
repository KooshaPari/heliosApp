{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["bun-types", "node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "@helios/runtime": ["apps/runtime/src/index.ts"],
      "@helios/runtime/*": ["apps/runtime/src/*"],
      "@helios/desktop": ["apps/desktop/src/index.ts"],
      "@helios/desktop/*": ["apps/desktop/src/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "playwright.config.ts",
    "docs/.vitepress/**/*.ts",
    "docs/.vitepress/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage", ".worktrees"]
}
