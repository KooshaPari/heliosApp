{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"allowImportingTsExtensions": false,
		"resolveJsonModule": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"types": ["bun-types", "node", "@playwright/test"],
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"paths": {
			"@helios/runtime": ["apps/runtime/src/index.ts"],
			"@helios/runtime/*": ["apps/runtime/src/*"],
			"@helios/desktop": ["apps/desktop/src/index.ts"],
			"@helios/desktop/*": ["apps/desktop/src/*"],
			"@helios/logger": ["packages/logger/src/index.ts"],
			"@helios/logger/*": ["packages/logger/src/*"],
			"@helios/runtime-core": ["packages/runtime-core/src/index.ts"],
			"@helios/runtime-core/*": ["packages/runtime-core/src/*"],
			"@helios/errors": ["packages/errors/src/index.ts"],
			"@helios/errors/*": ["packages/errors/src/*"],
			"@helios/ids": ["packages/ids/src/index.ts"],
			"@helios/ids/*": ["packages/ids/src/*"],
			"@helios/types": ["packages/types/src/index.ts"],
			"@helios/types/*": ["packages/types/src/*"],
			"@helios/colab-renderer": ["apps/colab-renderer/src/index.tsx"],
			"@helios/colab-renderer/*": ["apps/colab-renderer/src/*"]
		}
	},
	"include": [
		"apps/**/*.ts",
		"apps/**/*.tsx",
		"packages/*/src/**/*.ts",
		"packages/*/src/**/*.tsx",
		"playwright.config.ts",
		"docs/.vitepress/**/*.ts",
		"docs/.vitepress/**/*.d.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"coverage",
		".worktrees",
		"apps/runtime/tests/integration",
		"apps/desktop/tests/e2e",
		"apps/desktop/tests/unit/control_plane.test.ts",
		"apps/desktop/tests/unit/settings.test.ts"
	]
}
