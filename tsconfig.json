{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "types": ["bun-types", "node"]
  },
  "include": [
    "apps/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
