# heliosApp — Development Environment
# This file is used by Vite during development (npm run dev)

# Federation Configuration
FEDERATION_MODE=standalone

# Development
VITE_DEV_MODE=true
VITE_LOG_LEVEL=debug

# When heliosApp is used as a Module Federation remote,
# the host app will load this from http://localhost:3001/remoteEntry.js
# No additional config needed here unless building custom host integration
