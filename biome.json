{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "node_modules/**",
      "docs/.vitepress/dist/**",
      "apps/**/dist/**",
      "docs/.generated/**",
      ".worktrees/**",
      "agileplus/**",
      "docs/sessions/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 100,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "all": true
      },
      "correctness": {
        "all": true
      },
      "style": {
        "all": true
      },
      "complexity": {
        "all": true
      },
      "security": {
        "all": true
      }
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "asNeeded",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "semicolons": "always",
      "trailingComma": "es5"
    }
  },
  "overrides": [
    {
      "include": ["apps/desktop/src/runtime_client.ts"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    }
  ],
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  }
}
