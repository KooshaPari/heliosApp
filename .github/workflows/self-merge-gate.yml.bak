name: Self-Merge Gate

on:
  pull_request:
    types: [synchronize, opened, reopened]
    branches: [main]

jobs:
  check-merge-readiness:
    runs-on: ubuntu-latest
    name: Check Merge Readiness
    permissions:
      contents: read
      checks: read
      statuses: read
      pull-requests: write

    steps:
      - name: Check PR merge conditions
        id: check
        uses: actions/github-script@v7
        with:
          script: |
